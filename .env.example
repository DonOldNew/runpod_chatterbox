RUNPOD_API_KEY=rpa_xxxxx
RUNPOD_ENDPOINT_ID=kt5urlsfd32ky7

# Groq API (for Whisper STT) - Get key at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxx

# DeepSeek API (for LLM) - Get key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxx

# Voice cloning reference audio URL (optional)
# Set this to a URL of the target person's voice sample (WAV, min 6 seconds)
# VOICE_CLONE_URL=https://example.com/carolina.wav

# Streaming TTS endpoint ID (optional — self-hosted Chatterbox Streaming on RunPod)
# If set, uses streaming TTS (~500ms TTFB) instead of batch (~5-70s)
# Deploy Dockerfile.streaming to RunPod Serverless, then paste the endpoint ID here
# RUNPOD_STREAMING_ENDPOINT=abc123def456
